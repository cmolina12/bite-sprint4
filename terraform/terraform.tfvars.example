# =============================================================================
# Copia este archivo a `terraform.tfvars` y edita los valores.
# terraform.tfvars está en .gitignore — NUNCA lo commitees.
# =============================================================================

# -----------------------------------------------------------------------------
# Etapa 0 — Infra base (OBLIGATORIO)
# -----------------------------------------------------------------------------

# Tu IP pública. Obtener con: curl -s ifconfig.me
my_ip_cidr = "TU_IP/32"

# Password de RDS PostgreSQL. Alfanumérico, mínimo 8 chars.
# Genera con: openssl rand -hex 12
db_password = "BiteSprint3Lab"


# -----------------------------------------------------------------------------
# Etapa 1 — Manejador de Reportes (OBLIGATORIO)
# -----------------------------------------------------------------------------

reports_git_repo_url = "https://github.com/TU_USUARIO/bite-sprint3.git"
reports_git_ref      = "main"

# Genera con: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
django_secret_key = "GENERAR_CON_secrets.token_urlsafe"


# -----------------------------------------------------------------------------
# Etapa 3 — Auth0 (necesario para SEG-01 y SEG-02)
# -----------------------------------------------------------------------------
# Puedes dejarlos vacíos si solo vas a probar hasta Etapa 2.
# Si están vacíos, el middleware de tenant queda en "modo permisivo".
# Datos del Auth0 → Applications → BITE.co Web App → Settings

auth0_domain   = "dev-xxxxxxxx.us.auth0.com"
auth0_audience = "https://bite.co/api"
# IMPORTANTE: este claim debe coincidir EXACTO con el namespace del Action
# en Auth0. Si en el Action escribiste `const namespace = "https://bite.co";`
# entonces el claim aquí es "https://bite.co/tenant_id".
auth0_tenant_claim = "https://bite.co/tenant_id"

# Datos del Auth0 → Applications → BITE.co Backend M2M → Settings
auth0_mgmt_client_id     = "PEGA_TU_M2M_CLIENT_ID"
auth0_mgmt_client_secret = "PEGA_TU_M2M_CLIENT_SECRET"


# -----------------------------------------------------------------------------
# Etapa 4 — SMTP (Gmail App Password)
# -----------------------------------------------------------------------------
# Puedes dejar vacío si solo pruebas hasta Etapa 3.
# Configuración Gmail:
#   1. En la cuenta Gmail, activa 2FA
#   2. https://myaccount.google.com/apppasswords → crear App Password
#   3. Pegar los 16 chars (sin espacios) en smtp_password

smtp_user            = "bite.sprint3@gmail.com"
smtp_password        = "abcdefghijklmnop"
smtp_from            = "bite.sprint3@gmail.com"
security_admin_email = "tu.email.personal@gmail.com"
